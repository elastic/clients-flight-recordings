{
  "api": "count",
  "file": "/test/free/count/40_stats.yml",
  "name": "count with stats parameter (multiple comma-separated values)",
  "origin": "yaml",
  "request": {
    "args": {
      "index": "test_stats",
      "stats": [
        "group1",
        "group2",
        "group3"
      ]
    }
  },
  "response": {
    "headers": {
      "content-length": "71",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch",
      "x-elasticsearch-search-metrics": "store_bytes_read=0"
    },
    "payload": {
      "_shards": {
        "failed": 0,
        "skipped": 0,
        "successful": 1,
        "total": 1
      },
      "count": 2
    },
    "statusCode": 200
  }
}