{
  "api": "count",
  "file": "/test/free/count/40_stats.yml",
  "name": "count with stats parameter and query string",
  "origin": "yaml",
  "request": {
    "args": {
      "index": "test_stats",
      "q": "foo:bar",
      "stats": [
        "group1",
        "group2"
      ]
    }
  },
  "response": {
    "headers": {
      "content-length": "71",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "_shards": {
        "failed": 0,
        "skipped": 0,
        "successful": 1,
        "total": 1
      },
      "count": 1
    },
    "statusCode": 200
  }
}