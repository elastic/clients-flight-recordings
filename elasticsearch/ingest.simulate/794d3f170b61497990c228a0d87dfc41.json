{
  "api": "ingest.simulate",
  "file": "/test/platinum/mustache/10_webhook.yml",
  "name": "Test webhook action with mustache integration",
  "origin": "yaml",
  "request": {
    "args": {
      "body": {
        "docs": [
          {
            "_id": "id",
            "_index": "index",
            "_source": {
              "host": "172.18.0.2:9200"
            }
          }
        ],
        "pipeline": {
          "description": "_description",
          "processors": [
            {
              "grok": {
                "field": "host",
                "patterns": [
                  "(?:\\[(?<hostname>[^\\]]+)\\]|(?<hostname>%{IPORHOST})):(?<port>\\d+)"
                ]
              }
            },
            {
              "convert": {
                "field": "port",
                "type": "integer"
              }
            }
          ]
        }
      }
    }
  },
  "response": {
    "headers": {
      "content-length": "194",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "docs": [
        {
          "doc": {
            "_id": "id",
            "_index": "index",
            "_ingest": {
              "timestamp": "2026-06-26T11:17:48.974487533Z"
            },
            "_source": {
              "host": "172.18.0.2:9200",
              "hostname": "172.18.0.2",
              "port": 9200
            },
            "_version": "-3"
          }
        }
      ]
    },
    "statusCode": 200
  }
}