{
  "api": "indices.create",
  "file": "/test/free/indices.sort/30_multi_value.yml",
  "name": "Index Sort with doc_values multi_value false - integer",
  "origin": "yaml",
  "request": {
    "args": {
      "body": {
        "mappings": {
          "properties": {
            "rank": {
              "doc_values": {
                "multi_value": false
              },
              "type": "integer"
            }
          }
        },
        "settings": {
          "index": {
            "sort": {
              "field": "rank"
            }
          },
          "number_of_shards": 1,
          "refresh_interval": -1,
          "routing": {
            "rebalance": {
              "enable": "none"
            }
          }
        }
      },
      "index": "test"
    }
  },
  "response": {
    "headers": {
      "content-length": "63",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "acknowledged": true,
      "index": "test",
      "shards_acknowledged": true
    },
    "statusCode": 200
  }
}