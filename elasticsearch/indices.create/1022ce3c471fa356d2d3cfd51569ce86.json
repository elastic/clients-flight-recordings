{
  "api": "indices.create",
  "file": "/test/free/mapping/70_columnar_prefix_dynamic_properties.yml",
  "name": "columnar: index created with prefix_properties.enabled in mapping body is preserved on get_mapping",
  "origin": "yaml",
  "request": {
    "args": {
      "body": {
        "mappings": {
          "prefix_properties": {
            "attributes": {
              "enabled": false
            }
          }
        },
        "settings": {
          "index": {
            "mode": "columnar"
          }
        }
      },
      "index": "test_columnar_enabled_input"
    }
  },
  "response": {
    "headers": {
      "content-length": "86",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "acknowledged": true,
      "index": "test_columnar_enabled_input",
      "shards_acknowledged": true
    },
    "statusCode": 200
  }
}