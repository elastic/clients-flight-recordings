{
  "api": "indices.create",
  "file": "/test/free/search.vectors/60_dense_vector_dynamic_mapping.yml",
  "name": "Float arrays inside nested objects respect float dynamic templates and are not mapped as dense_vector",
  "origin": "yaml",
  "request": {
    "args": {
      "body": {
        "mappings": {
          "dynamic_templates": [
            {
              "my_float_template": {
                "mapping": {
                  "type": "float"
                },
                "match": "*float*"
              }
            }
          ]
        }
      },
      "index": "my-nested-dynamic-template-index"
    }
  },
  "response": {
    "headers": {
      "content-length": "91",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "acknowledged": true,
      "index": "my-nested-dynamic-template-index",
      "shards_acknowledged": true
    },
    "statusCode": 200
  }
}