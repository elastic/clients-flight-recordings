{
  "api": "indices.create",
  "file": "/test/free/aggregations/terms_text_docvalues.yml",
  "name": "Terms aggregation on text field with doc_values",
  "origin": "yaml",
  "request": {
    "args": {
      "body": {
        "mappings": {
          "properties": {
            "text_field": {
              "doc_values": true,
              "index": false,
              "type": "text"
            }
          }
        },
        "settings": {
          "number_of_shards": 1
        }
      },
      "index": "test_text_docvalues"
    }
  },
  "response": {
    "headers": {
      "content-length": "78",
      "content-type": "application/json",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "acknowledged": true,
      "index": "test_text_docvalues",
      "shards_acknowledged": true
    },
    "statusCode": 200
  }
}