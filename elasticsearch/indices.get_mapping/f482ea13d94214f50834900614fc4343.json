{
  "api": "indices.get_mapping",
  "file": "/test/free/mapping/70_columnar_prefix_dynamic_properties.yml",
  "name": "logsdb_columnar: multiple sub-objects with all three supported dynamic values",
  "origin": "yaml",
  "request": {
    "args": {
      "index": "test_logsdb_columnar_multi_prefix"
    }
  },
  "response": {
    "headers": {
      "content-type": "application/json",
      "transfer-encoding": "chunked",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "test_logsdb_columnar_multi_prefix": {
        "mappings": {
          "_data_stream_timestamp": {
            "enabled": true
          },
          "dynamic": "true",
          "prefix_properties": {
            "attributes": {
              "dynamic": "false"
            },
            "metrics": {
              "dynamic": "true"
            },
            "resource": {
              "dynamic": "strict"
            }
          },
          "properties": {
            "@timestamp": {
              "ignore_malformed": false,
              "type": "date"
            },
            "attributes.host": {
              "type": "keyword"
            },
            "metrics.cpu": {
              "type": "double"
            },
            "resource.service": {
              "type": "keyword"
            }
          }
        }
      }
    },
    "statusCode": 200
  }
}