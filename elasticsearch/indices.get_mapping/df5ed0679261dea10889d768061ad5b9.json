{
  "api": "indices.get_mapping",
  "file": "/test/free/mapping/70_columnar_prefix_dynamic_properties.yml",
  "name": "logsdb_columnar: index created with prefix_properties.enabled in mapping body is preserved on get_mapping",
  "origin": "yaml",
  "request": {
    "args": {
      "index": "test_logsdb_columnar_enabled_input"
    }
  },
  "response": {
    "headers": {
      "content-type": "application/json",
      "transfer-encoding": "chunked",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "test_logsdb_columnar_enabled_input": {
        "mappings": {
          "_data_stream_timestamp": {
            "enabled": true
          },
          "prefix_properties": {
            "attributes": {
              "enabled": false
            }
          },
          "properties": {
            "@timestamp": {
              "ignore_malformed": false,
              "type": "date"
            }
          }
        }
      }
    },
    "statusCode": 200
  }
}