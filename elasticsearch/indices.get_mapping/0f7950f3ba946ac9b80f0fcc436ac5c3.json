{
  "api": "indices.get_mapping",
  "file": "/test/free/mapping/70_columnar_prefix_dynamic_properties.yml",
  "name": "logsdb_columnar: put_mapping merge adds new enabled prefix",
  "origin": "yaml",
  "request": {
    "args": {
      "index": "test_logsdb_columnar_enabled_merge"
    }
  },
  "response": {
    "headers": {
      "content-type": "application/json",
      "transfer-encoding": "chunked",
      "x-elastic-product": "Elasticsearch"
    },
    "payload": {
      "test_logsdb_columnar_enabled_merge": {
        "mappings": {
          "_data_stream_timestamp": {
            "enabled": true
          },
          "prefix_properties": {
            "attributes": {
              "enabled": false
            },
            "resource": {
              "enabled": false
            }
          },
          "properties": {
            "@timestamp": {
              "ignore_malformed": false,
              "type": "date"
            }
          }
        }
      }
    },
    "statusCode": 200
  }
}