        "mappings": {
          "dynamic_templates": [
            {
              "dense_vector_template": {
                "mapping": {
                  "index": true,
                  "index_options": {
                    "type": "hnsw"
                  },
                  "similarity": "cosine",
                  "type": "dense_vector"
                },
                "path_match": "my_vectors.*"
              }
            }
          ],
          "properties": {
            "my_vectors": {
              "properties": {
                "vector1": {
                  "dims": 12,
                  "index": true,
                  "index_options": {
                    "ef_construction": 100,
                    "m": 16,
                    "type": "hnsw"
                  },
                  "similarity": "cosine",
                  "type": "dense_vector"
                }
              }
            }
          }
        }
      }
    },
    "statusCode": 200
  }
